{
  "name": "@vibecontrols/vibe-plugin-storage-skalex",
  "version": "2026.509.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "description": "Skalex storage provider for the VibeControls agent — document-oriented, file-backed, AES-256-GCM encryption at rest.",
  "engines": {
    "bun": ">=1.3.0"
  },
  "author": {
    "name": "Vignesh T.V",
    "email": "vignesh@burdenoff.com",
    "url": "https://github.com/tvvignesh"
  },
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --minify-syntax --minify-whitespace --external elysia && tsc --emitDeclarationOnly --declaration --outDir ./dist",
    "dev": "tsc --watch",
    "lint": "eslint ./src",
    "format": "bunx prettier . --write",
    "format:check": "bunx prettier . --check",
    "type:check": "tsc --noEmit",
    "test": "bun test tests/**/*.test.ts",
    "clean": "rimraf dist",
    "prebuild": "bun run clean",
    "prepublishOnly": "bun run build",
    "sanity": "bun run format:check && bun run lint && bun run type:check && bun run test && bun run build"
  },
  "dependencies": {
    "@vibecontrols/plugin-sdk": "2026.509.1",
    "skalex": "4.0.0-alpha.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.9",
    "eslint": "^9.30.1",
    "globals": "^17.3.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {
    "@vibecontrols/vibe-plugin-storage": "2026.508.5",
    "@vibecontrols/agent": ">=2026.428.0"
  },
  "peerDependenciesMeta": {
    "@vibecontrols/agent": {
      "optional": true
    }
  },
  "keywords": [
    "vibecontrols",
    "vibe",
    "vibe-plugin",
    "storage",
    "skalex",
    "encryption",
    "bun"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algoshred/vibe-plugin-storage-skalex.git"
  },
  "bugs": {
    "url": "https://github.com/algoshred/vibe-plugin-storage-skalex/issues"
  },
  "homepage": "https://vibecontrols.com",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://verdaccio.tooling.internal.burdenoff.com/"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ]
}
